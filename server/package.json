{
  "name": "server",
  "version": "1.0.0",
  "description": "REST API for the Vintage Typewriter writing station",
  "main": "dist/app.js",
  "scripts": {
    "start": "node dist/app.js",
    "build": "tsc",
    "dev": "nodemon src/app.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
